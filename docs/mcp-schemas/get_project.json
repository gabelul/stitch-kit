          },
          "fontSize": {
            "type": "string",
            "description": "Optional. CSS font-size value (e.g. \"1rem\")."
          },
          "fontWeight": {
            "type": "string",
            "description": "Optional. CSS font-weight value (e.g. \"600\")."
          },
          "letterSpacing": {
            "type": "string",
            "description": "Optional. CSS letter-spacing value."
          },
          "lineHeight": {
            "type": "string",
            "description": "Optional. CSS line-height value."
          }
        },
        "type": "object"
