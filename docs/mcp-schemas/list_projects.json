              "IMAGE_TO_UI",
              "IMAGE_TO_UI_PRO",
              "PROJECT_DESIGN"
            ],
            "type": "string"
          },
          "readTime": {
            "format": "date-time",
            "readOnly": true,
            "type": "string"
          },
          "screenInstances": {
            "items": {
              "$ref": "#/$defs/ScreenInstance"
            },
            "readOnly": true,
            "type": "array"
          },
          "thumbnailScreenshot": {
            "$ref": "#/$defs/File"
          },
          "title": {
            "type": "string"
          },
          "updateTime": {
            "format": "date-time",
            "readOnly": true,
            "type": "string"
          },
          "visibility": {
            "enum": [
              "VISIBILITY_UNSPECIFIED",
              "PUBLIC",
              "PRIVATE"
            ],
            "type": "string"
          }
        },
        "type": "object"
